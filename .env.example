# ─────────────────────────────────────────────────────────────────────────────
# Surat Food Chain — environment template. Copy to `.env` and fill real values.
# The root `.env` is consumed by docker-compose AND by both apps (via dotenv).
# NEVER commit the real `.env` — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (docker-compose) ────────────────────────────────────────────────
POSTGRES_USER=surat
POSTGRES_PASSWORD=surat_dev_pwd
POSTGRES_DB=surat_food_chain
POSTGRES_PORT=5432

# ── API (apps/api) ───────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
# Prisma connection string — must match the Postgres vars above.
DATABASE_URL=postgresql://surat:surat_dev_pwd@localhost:5432/surat_food_chain?schema=public

# JWT — generate strong random values for production (openssl rand -base64 48).
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS / web origin
WEB_ORIGIN=http://localhost:3000

# Razorpay (test mode). Get keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=set_this_in_razorpay_dashboard_webhook_config

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20

# Caching / jobs
KPI_CACHE_TTL_SECONDS=60
MATERIALIZED_VIEW_REFRESH_CRON=*/15 * * * *

# ── Web (apps/web) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

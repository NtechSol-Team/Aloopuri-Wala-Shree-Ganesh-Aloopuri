  session PosSession           @relation(fields: [sessionId], references: [id])
  items   PosTransactionItem[]

  @@index([sessionId])
  @@index([outletId, soldAt])
  @@index([status])
  @@index([outletId, kotStatus])
  @@map("pos_transactions")
}

model PosTransactionItem {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId       String   @map("transaction_id") @db.Uuid
  // Exactly one source is set: menuItemId for menu-based sales (the current
  // model), productId for historical catalog-based sales made before menus
  // existed. Both are nullable and the line is self-contained via the snapshot
  // fields below, so a sale survives even if its source item is later deleted.
  productId           String?  @map("product_id") @db.Uuid
  menuItemId          String?  @map("menu_item_id") @db.Uuid
  productNameSnapshot String   @map("product_name_snapshot")
  quantity            Decimal  @db.Decimal(12, 2)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 2)
  discount            Decimal  @default(0) @db.Decimal(12, 2)
  taxPercent          Decimal  @map("tax_percent") @db.Decimal(5, 2)
  taxAmount           Decimal  @map("tax_amount") @db.Decimal(12, 2)
  lineTotal           Decimal  @map("line_total") @db.Decimal(12, 2)
  isDeleted           Boolean  @default(false) @map("is_deleted")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  transaction PosTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  menuItem    MenuItem?      @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([productId])
  @@index([menuItemId])
  @@map("pos_transaction_items")
}

// ─────────────────────────────── ANALYTICS ──────────────────────────────────

// Periodic KPI snapshots (distinct from the SQL materialized views, which are
// created in the audit_and_views migration and refreshed by a pg-boss job).
model AnalyticsSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotType String   @map("snapshot_type")
  snapshotDate DateTime @map("snapshot_date") @db.Date
  scope        String   @default("GLOBAL") // 'GLOBAL' or an outlet id
  data         Json
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([snapshotType, snapshotDate, scope])
  @@index([snapshotType, snapshotDate])
  @@map("analytics_snapshots")
}

// Atomic per-document-type counters for human-friendly numbers
// (bills, orders, transfers, batches, payments, POS receipts, user codes).
model DocumentCounter {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique // e.g. BILL, ORDER, TRANSFER, BATCH, PAYMENT, POS_RECEIPT
  value     BigInt   @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("document_counters")
}

// ─────────────────────────────── ACCOUNTS PAYABLE ───────────────────────────

// A supplier purchase bill (payable). Raw-material goods receipts and "other"
// expense lines link back to it; supplier payments settle the balance.
model SupplierBill {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billNumber    String             @unique @map("bill_number")
  supplierName  String?            @map("supplier_name")
  supplierGstin String?            @map("supplier_gstin")
  invoiceNumber String?            @map("invoice_number")
  billDate      DateTime           @default(now()) @map("bill_date") @db.Timestamptz(6)
  taxableAmount Decimal            @default(0) @map("taxable_amount") @db.Decimal(12, 2)
  cgst          Decimal            @default(0) @db.Decimal(12, 2)
  sgst          Decimal            @default(0) @db.Decimal(12, 2)
  igst          Decimal            @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal            @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount   Decimal            @map("total_amount") @db.Decimal(12, 2)
  amountPaid    Decimal            @default(0) @map("amount_paid") @db.Decimal(12, 2)
  balanceDue    Decimal            @map("balance_due") @db.Decimal(12, 2)
  status        SupplierBillStatus @default(UNPAID)
  paymentMethod PaymentMethod?     @map("payment_method")
  // Credit terms: set only when the bill isn't paid in full at entry.
  creditDays    Int?               @map("credit_days")
  dueDate       DateTime?          @map("due_date") @db.Timestamptz(6)
  // Whether this purchase carries GST (unregistered/composition suppliers often don't).
  isGstBill     Boolean            @default(true) @map("is_gst_bill")
  notes         String?
  isDeleted     Boolean            @default(false) @map("is_deleted")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById   String?            @map("created_by") @db.Uuid

  payments     SupplierPayment[]
  intakeLines  RawMaterialIntake[]
  expenseLines Expense[]
  items        SupplierBillItem[]

  @@index([status, billDate])
  @@index([supplierName])
  @@index([status, dueDate])
  @@map("supplier_bills")
}

// Itemized line of a supplier purchase bill (raw material / finished good / other).
model SupplierBillItem {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierBillId String           @map("supplier_bill_id") @db.Uuid
  kind           PurchaseLineKind
  refId          String?          @map("ref_id") @db.Uuid // rawMaterialId / productId / categoryId
  name           String // snapshot of the item/category name
  hsnCode        String?          @map("hsn_code")
  quantity       Decimal?         @db.Decimal(12, 2)
  unitCost       Decimal?         @map("unit_cost") @db.Decimal(12, 2)
  taxRate        Decimal          @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxableAmount  Decimal          @map("taxable_amount") @db.Decimal(12, 2)
  taxAmount      Decimal          @default(0) @map("tax_amount") @db.Decimal(12, 2)
  lineTotal      Decimal          @map("line_total") @db.Decimal(12, 2)
  isDeleted      Boolean          @default(false) @map("is_deleted")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  bill SupplierBill @relation(fields: [supplierBillId], references: [id], onDelete: Cascade)

  @@index([supplierBillId])
  @@map("supplier_bill_items")
}

// Insert-only payment made to a supplier against a bill.
model SupplierPayment {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentNumber  String        @unique @map("payment_number")
  supplierBillId String        @map("supplier_bill_id") @db.Uuid
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod
  paymentDate    DateTime      @default(now()) @map("payment_date") @db.Timestamptz(6)
  notes          String?
  paidById       String?       @map("paid_by") @db.Uuid
  isDeleted      Boolean       @default(false) @map("is_deleted")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById    String?       @map("created_by") @db.Uuid

  bill SupplierBill @relation(fields: [supplierBillId], references: [id])

  @@index([supplierBillId])
  @@index([paymentDate])
  @@map("supplier_payments")
}

// ─────────────────────────────── CONTACT MASTER (GST) ───────────────────────

enum ContactType {
  CUSTOMER
  SUPPLIER
  OTHER
}

model Contact {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type              ContactType @default(CUSTOMER)
  name              String
  gstin             String?
  legalName         String?     @map("legal_name")
  tradeName         String?     @map("trade_name")
  stateCode         String?     @map("state_code")
  stateName         String?     @map("state_name")
  address           String?
  phone             String?
  whatsapp          String?
  email             String?
  // Bank details — all optional, mainly useful for suppliers/other paid by transfer.
  bankAccountHolder String?     @map("bank_account_holder")
  bankName          String?     @map("bank_name")
  bankAccountNumber String?     @map("bank_account_number")
  bankIfsc          String?     @map("bank_ifsc")
  isActive          Boolean     @default(true) @map("is_active")
  isDeleted         Boolean     @default(false) @map("is_deleted")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById       String?     @map("created_by") @db.Uuid

  @@index([type])
  @@index([gstin])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────────────────────
// Surat Food Chain — Prisma schema
//
// Conventions (applied to every domain table):
//   • id            UUID PK, DB-generated via gen_random_uuid()
//   • createdAt     TIMESTAMPTZ default now()
//   • updatedAt     TIMESTAMPTZ @updatedAt
//   • isDeleted     soft delete (no hard deletes in a financial system)
//   • createdById   the user who created the row (app-enforced)
//
// Money is ALWAYS Decimal(12,2). Tax rate is Decimal(5,2). Quantities that may
// be fractional (BOM ratios, consumption) use Decimal(12,4).
//
// Advanced DB objects that Prisma does not model — audit triggers, materialized
// views and their refresh function — live in a follow-up SQL migration
// (see prisma/migrations/*_audit_and_views). They are drift-exempt.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm]
}

// ─────────────────────────────── ENUMS ──────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  GODOWN_MANAGER
  FRANCHISE_OWNER
  CASHIER
}

enum MeasurementUnit {
  KG
  GRAM
  LITRE
  ML
  PIECE
  PACKET
  BOX
  DOZEN
}

enum StockTransferStatus {
  DRAFT
  DISPATCHED
  RECEIVED
  CANCELLED
}

enum TransferDestination {
  MAIN_BRANCH
  OUTLET
}

// A BOM/production line consumes either a raw material or another finished
// product (a semi-finished component, e.g. Khawsa used to make frozen Khawsa).
enum BomComponentType {
  RAW_MATERIAL
  PRODUCT
}

/// Outlet order lifecycle. An order is only CONFIRMED once it has been paid for
/// online, or approved as a credit order by the main owner.
///   PAYMENT_PENDING         → placed; outlet must pay online or request credit
///   CREDIT_APPROVAL_PENDING → credit requested; waiting on the main owner
///   CONFIRMED               → paid or credit-approved; bill generated
///   DISPATCHED              → goods left the source; awaiting outlet receipt
///   DELIVERED               → outlet confirmed receipt; stock is theirs
enum OutletOrderStatus {
  PAYMENT_PENDING
  CREDIT_APPROVAL_PENDING
  CONFIRMED
  DISPATCHED
  DELIVERED
  CANCELLED
}

/// How the outlet chose to settle an order at placement time.
enum OrderPaymentMode {
  ONLINE
  CREDIT
}

// Where confirmed stock is pulled from when the order is delivered.
enum FulfillmentSource {
  MAIN_BRANCH
  GODOWN
}

enum BillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  CANCELLED
}

// Coarse channel: digital gateway vs manual cash entry.
enum PaymentChannel {
  DIGITAL
  CASH
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  NET_BANKING
  RAZORPAY
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SupplierBillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum PurchaseLineKind {
  RAW_MATERIAL
  FINISHED_GOOD
  OTHER
}

enum ExpenseLocation {
  GODOWN
  MAIN_BRANCH
  GENERAL
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum PosTransactionStatus {
  COMPLETED
  VOID
  HELD
}

// Kitchen order ticket lifecycle for the prep-counter board.
enum KotStatus {
  PREPARING
  READY
  DELIVERED
}

enum PosPaymentMode {
  CASH
  CARD
  UPI
  SPLIT
}

/// Whether a counter sale is eaten in / served on a plate (DINE_IN, the
/// default) or packed to go (PARCEL) — printed on the receipt and flagged on
/// the kitchen ticket so kitchen staff pack rather than plate it.
enum PosOrderType {
  DINE_IN
  PARCEL
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE
}

// ─────────────────────────────── AUTH / USERS ───────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @map("user_code") // human-friendly login id e.g. EMP001
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  role         UserRole
  outletId     String?  @map("outlet_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById  String?  @map("created_by") @db.Uuid

  outlet   Outlet?       @relation("OutletMembers", fields: [outletId], references: [id])
  sessions UserSession[]

  @@index([role])
  @@index([outletId])
  @@index([isDeleted])
  @@map("users")
}

model UserSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceName       String?   @map("device_name")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  lastActiveAt     DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(6)
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  isDeleted        Boolean   @default(false) @map("is_deleted")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ─────────────────────────────── OUTLETS ────────────────────────────────────

// GENERIC = standard catalog price for everyone. SPECIAL = this outlet has its own
// negotiated price list (OutletProductPrice); falls back to catalog price per product
// if that product has no special price set.
enum PricingMode {
  GENERIC
  SPECIAL
}

model Outlet {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  code             String      @unique
  address          String?
  phone            String?
  ownerUserId      String?     @map("owner_user_id") @db.Uuid // app-enforced ref to users.id
  creditPeriodDays Int         @default(15) @map("credit_period_days")
  pricingMode      PricingMode @default(GENERIC) @map("pricing_mode")
  // Whether this outlet is billed with GST. Decided when the outlet is created,
  // because their orders are priced (and paid for) before anyone reviews them.
  gstBilling       Boolean     @default(true) @map("gst_billing")

  // Which POS menu this outlet sells from. The Main Owner assigns it; the outlet
  // only ever loads its assigned menu at the counter. Null = fall back to the
  // default menu (also what the main-branch till uses). SetNull on menu delete
  // so removing a menu never orphans an outlet row.
  assignedMenuId String? @map("assigned_menu_id") @db.Uuid

  // ── Outlet's own business identity ───────────────────────────────────────
  // Each outlet is its own shop: it sells to walk-in customers under its own
  // registration, so its POS receipts must carry ITS address and GSTIN, not the
  // parent company's. These also appear as the buyer's details on the invoices
  // the main branch raises against the outlet.
  legalName     String?  @map("legal_name") // registered name, if it differs from the display name
  gstin         String? // 15-char GSTIN, validated on save
  fssaiNumber   String?  @map("fssai_number") // food licence — legally required on food receipts
  email         String?
  receiptFooter String?  @map("receipt_footer") // optional closing line on the outlet's receipts
  isActive      Boolean  @default(true) @map("is_active")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById   String?  @map("created_by") @db.Uuid

  members         User[]               @relation("OutletMembers")
  orders          OutletOrder[]
  bills           Bill[]
  payments        Payment[]
  outletStock     OutletStock[]
  posSessions     PosSession[]
  directTransfers StockTransfer[]      @relation("OutletDirectTransfers")
  specialPrices   OutletProductPrice[]
  documents       OutletDocument[]
  assignedMenu    Menu?                @relation(fields: [assignedMenuId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([isDeleted])
  @@index([assignedMenuId])
  @@map("outlets")
}

// Per-outlet negotiated price for a specific product (only consulted when the
// outlet's pricingMode = SPECIAL). Absence of a row = fall back to catalog price.
model OutletProductPrice {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId  String   @map("outlet_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([outletId, productId])
  @@index([outletId])
  @@map("outlet_product_prices")
}

/// Paperwork an outlet is required to hold (and the main owner needs on file).
enum OutletDocumentCategory {
  GST_CERTIFICATE
  FSSAI_LICENSE
  PAN_CARD
  AGREEMENT
  RENT_DEED
  OTHER
}

/// A scanned document belonging to an outlet — GST certificate, food licence,
/// franchise agreement, and so on.
///
/// `storagePath` is a private path on disk, deliberately NOT under the publicly
/// served /uploads route: these are licences and signed agreements, so they are
/// streamed only through an authenticated endpoint that checks the caller.
model OutletDocument {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outletId     String                 @map("outlet_id") @db.Uuid
  title        String
  category     OutletDocumentCategory @default(OTHER)
  fileName     String                 @map("file_name") // original name, shown in the UI
  storagePath  String                 @map("storage_path") // private, server-side path
  mimeType     String                 @map("mime_type")
  sizeBytes    Int                    @map("size_bytes")
  notes        String?
  uploadedById String?                @map("uploaded_by") @db.Uuid
  isDeleted    Boolean                @default(false) @map("is_deleted")
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  outlet Outlet @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@map("outlet_documents")
}

// ─────────────────────────────── CATALOG ────────────────────────────────────

model ProductCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?  @map("created_by") @db.Uuid

  products Product[]

  @@map("product_categories")
}

model Product {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  sku                  String          @unique
  categoryId           String          @map("category_id") @db.Uuid
  unit                 MeasurementUnit
  basePrice            Decimal         @map("base_price") @db.Decimal(12, 2)
  mrp                  Decimal         @db.Decimal(12, 2)
  taxPercent           Decimal         @default(0) @map("tax_percent") @db.Decimal(5, 2)
  photoUrl             String?         @map("photo_url")
  reorderLevel         Decimal         @default(0) @map("reorder_level") @db.Decimal(12, 2)
  batchTrackingEnabled Boolean         @default(false) @map("batch_tracking_enabled")
  isActive             Boolean         @default(true) @map("is_active")
  // Whether this product is sellable directly at the POS counter (distinct from
  // being an active catalog item — e.g. wholesale-only products can stay active
  // for franchise ordering but be hidden from the cashier's tap-to-sell grid).
  isPosEnabled         Boolean         @default(true) @map("is_pos_enabled")
  // Manual sort position on the POS tap-to-sell grid (lower = earlier). Set by
  // dragging cards in the counter UI; 0 for non-POS items. Ties break by SKU.
  displayOrder         Int             @default(0) @map("display_order")
  // Whether this product has real finished-goods stock (godown/main-branch/outlet
  // ledgers). Off for counter items sold without formal inventory (e.g. made-to-order
  // or resold-as-is) — POS sales of these skip the stock check and don't decrement anything.
  trackInventory       Boolean         @default(true) @map("track_inventory")
  // Rolling weighted-average production cost per unit (material + component + overhead).
  avgCost              Decimal         @default(0) @map("avg_cost") @db.Decimal(12, 2)
  isDeleted            Boolean         @default(false) @map("is_deleted")
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById          String?         @map("created_by") @db.Uuid

  category            ProductCategory       @relation(fields: [categoryId], references: [id])
  bom                 BillOfMaterials[]     @relation("BomOutput")
  usedInBom           BillOfMaterials[]     @relation("BomComponent")
  godownStock         GodownStock?
  mainBranchStock     MainBranchStock?
  outletStock         OutletStock[]
  transferItems       StockTransferItem[]
  orderItems          OutletOrderItem[]
  billItems           BillItem[]
  productionBatches   ProductionBatch[]
  batchComponentItems ProductionBatchItem[] @relation("BatchComponent")
  posItems            PosTransactionItem[]
  outletSpecialPrices OutletProductPrice[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isDeleted])
  // Trigram GIN indexes for fast fuzzy search on product name + SKU.
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([sku(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("products")
}

// ─────────────────────────────── MENUS ──────────────────────────────────────
//
// A Menu is an outlet-assignable, self-contained POS menu: its categories and
// items are its OWN copies, NOT references to the shared Product catalog. This
// is deliberate — the Main Owner can clone a menu and then edit one outlet's
// prices/categories without touching any other menu (Vesu ₹280 vs Adajan ₹240
// for the "same" item are just two independent MenuItem rows). Only the Main
// Owner (SUPER_ADMIN) manages menus; outlets only ever load their assigned one.
//
// Menu items are counter items sold as-is (no stock ledger), which is why POS
// sales of them don't touch inventory — matching how the shop already runs.

model Menu {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  // The menu used when an outlet has no assignment, and by the main-branch till.
  // Soft invariant (enforced in the service): at most one default at a time.
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?  @map("created_by") @db.Uuid

  categories MenuCategory[]
  items      MenuItem[]
  outlets    Outlet[]

  @@index([isDeleted])
  @@map("menus")
}

model MenuCategory {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId       String   @map("menu_id") @db.Uuid
  name         String
  displayOrder Int      @default(0) @map("display_order")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  menu  Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items MenuItem[]

  @@index([menuId])
  @@map("menu_categories")
}

model MenuItem {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId       String          @map("menu_id") @db.Uuid
  categoryId   String?         @map("category_id") @db.Uuid
  name         String
  // Optional short code for barcode/quick search (not unique — the same item can
  // exist in several menus).
  code         String?
  unit         MeasurementUnit @default(PIECE)
  // GST-inclusive counter price (same convention as the current POS mrp).
  price        Decimal         @db.Decimal(12, 2)
  taxPercent   Decimal         @default(0) @map("tax_percent") @db.Decimal(5, 2)
  photoUrl     String?         @map("photo_url")
  displayOrder Int             @default(0) @map("display_order")
  // Availability toggle — an unavailable item stays on the menu but is hidden
  // from (or greyed out on) the counter grid.
  isAvailable  Boolean         @default(true) @map("is_available")
  isDeleted    Boolean         @default(false) @map("is_deleted")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  menu     Menu                 @relation(fields: [menuId], references: [id], onDelete: Cascade)
  category MenuCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  posItems PosTransactionItem[]

  @@index([menuId])
  @@index([categoryId])
  @@index([isDeleted])
  @@map("menu_items")
}

model RawMaterial {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  unit         MeasurementUnit
  supplierName String?         @map("supplier_name")
  reorderLevel Decimal         @default(0) @map("reorder_level") @db.Decimal(12, 2)
  currentStock Decimal         @default(0) @map("current_stock") @db.Decimal(12, 2)
  costPerUnit  Decimal         @default(0) @map("cost_per_unit") @db.Decimal(12, 2)
  isActive     Boolean         @default(true) @map("is_active")
  isDeleted    Boolean         @default(false) @map("is_deleted")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById  String?         @map("created_by") @db.Uuid

  bom        BillOfMaterials[]
  intake     RawMaterialIntake[]
  batchItems ProductionBatchItem[]

  @@index([isActive])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("raw_materials")
}

model BillOfMaterials {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId          String           @map("product_id") @db.Uuid // the output product this recipe builds
  componentType      BomComponentType @default(RAW_MATERIAL) @map("component_type")
  rawMaterialId      String?          @map("raw_material_id") @db.Uuid // set when componentType = RAW_MATERIAL
  componentProductId String?          @map("component_product_id") @db.Uuid // set when componentType = PRODUCT
  quantity           Decimal          @db.Decimal(12, 4) // component qty per 1 unit of output product
  isDeleted          Boolean          @default(false) @map("is_deleted")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?          @map("created_by") @db.Uuid

  product          Product      @relation("BomOutput", fields: [productId], references: [id])
  rawMaterial      RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  componentProduct Product?     @relation("BomComponent", fields: [componentProductId], references: [id])

  @@index([productId])
  @@index([rawMaterialId])
  @@index([componentProductId])
  @@map("bill_of_materials")
}

// ─────────────────────────────── PRODUCTION ─────────────────────────────────

model ProductionBatch {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchNumber       String   @unique @map("batch_number")
  productId         String   @map("product_id") @db.Uuid
  quantityProduced  Decimal  @map("quantity_produced") @db.Decimal(12, 2)
  totalMaterialCost Decimal  @default(0) @map("total_material_cost") @db.Decimal(12, 2) // raw + component cost
  overheadCost      Decimal  @default(0) @map("overhead_cost") @db.Decimal(12, 2) // electricity/gas/labour/etc.
  costPerUnit       Decimal  @default(0) @map("cost_per_unit") @db.Decimal(12, 2) // (material + overhead) / quantity
  productionDate    DateTime @map("production_date") @db.Timestamptz(6)
  notes             String?
  isDeleted         Boolean  @default(false) @map("is_deleted")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById       String?  @map("created_by") @db.Uuid

  product   Product               @relation(fields: [productId], references: [id])
  items     ProductionBatchItem[]
  overheads ProductionOverhead[]

  @@index([productId, productionDate])
  @@index([productionDate])
  @@map("production_batches")
}

model ProductionBatchItem {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId            String           @map("batch_id") @db.Uuid
  componentType      BomComponentType @default(RAW_MATERIAL) @map("component_type")
  rawMaterialId      String?          @map("raw_material_id") @db.Uuid
  componentProductId String?          @map("component_product_id") @db.Uuid
  nameSnapshot       String?          @map("name_snapshot") // component name at production time
  quantityConsumed   Decimal          @map("quantity_consumed") @db.Decimal(12, 4)
  unitCostSnapshot   Decimal          @map("unit_cost_snapshot") @db.Decimal(12, 2)
  lineCost           Decimal          @map("line_cost") @db.Decimal(12, 2)
  isDeleted          Boolean          @default(false) @map("is_deleted")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  batch            ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rawMaterial      RawMaterial?    @relation(fields: [rawMaterialId], references: [id])
  componentProduct Product?        @relation("BatchComponent", fields: [componentProductId], references: [id])

  @@index([batchId])
  @@index([rawMaterialId])
  @@index([componentProductId])
  @@map("production_batch_items")
}

// Non-material production costs allocated to a batch (electricity, gas, labour,
// packaging…). Costing-only — does NOT post to expenses/P&L (that is booked
// separately when the actual bill is paid), so there is no double counting.
model ProductionOverhead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batchId   String   @map("batch_id") @db.Uuid
  label     String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  batch ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("production_overheads")
}

model RawMaterialIntake {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rawMaterialId  String   @map("raw_material_id") @db.Uuid
  quantity       Decimal  @db.Decimal(12, 2)
  costPerUnit    Decimal  @map("cost_per_unit") @db.Decimal(12, 2)
  totalCost      Decimal  @map("total_cost") @db.Decimal(12, 2)
  supplierName   String?  @map("supplier_name")
  invoiceNumber  String?  @map("invoice_number")
  intakeDate     DateTime @map("intake_date") @db.Timestamptz(6)
  notes          String?
  hsnCode        String?  @map("hsn_code")
  taxRate        Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  supplierBillId String?  @map("supplier_bill_id") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById    String?  @map("created_by") @db.Uuid


model OutletOrder {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber        String             @unique @map("order_number")
  outletId           String             @map("outlet_id") @db.Uuid
  status             OutletOrderStatus  @default(PAYMENT_PENDING)
  orderDate          DateTime           @default(now()) @map("order_date") @db.Timestamptz(6)
  confirmedAt        DateTime?          @map("confirmed_at") @db.Timestamptz(6)
  dispatchedAt       DateTime?          @map("dispatched_at") @db.Timestamptz(6)
  deliveredAt        DateTime?          @map("delivered_at") @db.Timestamptz(6)
  // How the outlet chose to settle this order — picked right after placing it.
  paymentMode        OrderPaymentMode?  @map("payment_mode")
  // Razorpay order id of the in-flight/last checkout attempt (online orders only).
  razorpayOrderId    String?            @map("razorpay_order_id")
  // Set at dispatch: which location the stock was pulled from.
  fulfillmentSource  FulfillmentSource? @map("fulfillment_source")
  // Whether the resulting bill carries GST — seeded from the outlet's billing
  // preference at placement (the price the outlet pays depends on it), and still
  // adjustable by the main owner while approving a credit order.
  isGstBill          Boolean            @default(true) @map("is_gst_bill")
  // Credit approval / rejection trail.
  approvedAt         DateTime?          @map("approved_at") @db.Timestamptz(6)
  approvedById       String?            @map("approved_by") @db.Uuid
  cancelledAt        DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  cancelledById      String?            @map("cancelled_by") @db.Uuid
  cancellationReason String?            @map("cancellation_reason")
  notes              String?
  isDeleted          Boolean            @default(false) @map("is_deleted")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?            @map("created_by") @db.Uuid

  outlet Outlet            @relation(fields: [outletId], references: [id])

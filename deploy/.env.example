# Copy to deploy/.env on the server and fill in. Never commit deploy/.env.

# The one public origin users hit (Caddy). Examples:
#   http://139.59.xx.xx          — IP-only, before DNS exists
#   https://erp.yourdomain.com   — once a domain points at the droplet
PUBLIC_ORIGIN=http://YOUR_DROPLET_IP

# What Caddy listens on. ":80" for IP-only HTTP.
# Set to the bare domain (e.g. erp.yourdomain.com) to get automatic HTTPS.
SITE_ADDRESS=:80

# Generate strong values:  openssl rand -hex 32
POSTGRES_PASSWORD=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# GST home state (24 = Gujarat)
HOME_STATE_CODE=24

# Payments (test keys are fine to start; live keys when going to production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional integrations / letterhead
GSTZEN_API_KEY=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_GSTIN=
